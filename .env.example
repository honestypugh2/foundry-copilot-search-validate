# =============================================================================
# Foundry Copilot Search Validate - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# Azure AI Foundry / Project
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/yourProject
AZURE_AI_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/yourProject

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_api_key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/


# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your_search_admin_key
AZURE_SEARCH_INDEX_NAME=<your-index-name>

# Azure AI Search Connection (for Foundry Agent)
AI_SEARCH_PROJECT_CONNECTION_ID=your_connection_id

# Authentication
# true = Use Managed Identity / AzureCliCredential (recommended)
# false = Use API key authentication
USE_MANAGED_IDENTITY=true

# Agent Service Selection
# agent-framework = Use Microsoft Agent Framework SDK (default)
# foundry = Use Azure AI Foundry Agent Service
AGENT_SERVICE=agent-framework

# Knowledge Base Path
KNOWLEDGE_BASE_PATH=./data/knowledge_base

# Logging and Monitoring
LOG_LEVEL=INFO
AZURE_APPLICATION_INSIGHTS_CONNECTION_STRING=

# ============================================
# EXTRACTION BACKEND CONFIGURATION
# ============================================
# Options: document_intelligence (default), content_understanding
EXTRACTION_BACKEND=document_intelligence

# ============================================
# BLOB STORAGE CONFIGURATION (Optional)
# ============================================
# Set to true to store uploaded files in Azure Blob Storage
USE_BLOB_STORAGE=false

# Azure Storage Account (when USE_BLOB_STORAGE=true)
AZURE_STORAGE_CONNECTION_STRING=
# OR use account URL with managed identity:
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=<your-container-name>

# Local storage path (when USE_BLOB_STORAGE=false)
LOCAL_STORAGE_PATH=./data/uploads
