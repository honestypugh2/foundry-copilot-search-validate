# =============================================================================
# LAB - HR Policy Knowledge Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_INDEX_NAME=<your-index-name>
AZURE_SEARCH_API_KEY=<your-search-admin-key>

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=<your-openai-api-key>
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_DEPLOYMENT_NAME=<your-deployment-name>
AZURE_OPENAI_GPT_DEPLOYMENT=<your-deployment-name>
AZURE_OPENAI_GPT_MODEL=<your-model-name>

# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=https://<your-cognitive-service>.services.ai.azure.com/api/projects/<your-project-name>
AI_SEARCH_PROJECT_CONNECTION_ID=/subscriptions/<subscription-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>/connections/<connection-name>
AZURE_AI_MODEL_DEPLOYMENT_NAME=<your-deployment-name>

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=<your-storage-account-name>
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net/
AZURE_STORAGE_CONTAINER_NAME=<your-container-name>
AZURE_STORAGE_RESOURCE_ID=/subscriptions/<subscription-id>/resourceGroups/<rg>/providers/Microsoft.Storage/storageAccounts/<account-name>

# Feature Flags
USE_AZURE_SERVICES=true
USE_MANAGED_IDENTITY=true

# Logging and Monitoring
LOG_LEVEL=INFO
AZURE_APPLICATION_INSIGHTS_CONNECTION_STRING=<your-app-insights-connection-string>

# Agent Service Selection
# agent-framework = Use Microsoft Agent Framework SDK
# foundry = Use Azure AI Foundry Agent Service (default)
AGENT_SERVICE=foundry

# Foundry Agent Pipeline
# single_agent = MS recommended single-agent MCP pattern (default)
# multi_step = Legacy 4-step pipeline (learning reference)
PIPELINE_MODE=single_agent
# Enable post-processing citation validation (true/false)
VALIDATE_CITATIONS=false
# Keep Foundry Agents after invocation instead of cleaning up (true/false)
PERSIST_FOUNDRY_AGENTS=true

# Orchestrator Pattern Selection
# A = Single-agent MCP with instruction-driven file-location extraction (default)
# B = Hybrid: MCP + Direct Metadata Lookup tool (deterministic file paths)
ORCHESTRATOR_PATTERN=A

# Copilot Studio (optional)
COPILOT_STUDIO_ENVIRONMENT_ID=<your-environment-id>
COPILOT_STUDIO_BOT_ID=<your-bot-id>
COPILOT_STUDIO_AGENT_SCHEMA=<your-agent-schema>
COPILOT_STUDIO_REGION=unitedstates
# Override with the full token endpoint URL if the constructed URL doesn't work:
# COPILOT_STUDIO_TOKEN_ENDPOINT=https://default...environment.api.powerplatform.com/powervirtualagents/botsbyschema/.../directline/token

# Azure AI Project Resource ID (for RBAC / resource provisioning)
AZURE_AI_PROJECT_RESOURCE_ID=/subscriptions/<subscription-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>
